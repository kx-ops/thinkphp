# 忽略 Git 目录
.git
.gitignore

# 忽略 GitHub Actions 配置
.github

# 忽略本地开发配置和文档
README.md
docker-compose.yml
docker/
docs/

# 忽略 PHP 依赖和缓存 (由 Dockerfile 重新生成)
vendor/
node_modules/
.phpunit.result.cache
storage/logs/*.log

# 忽略敏感文件
.env
*.key
*.pem

# 忽略 IDE 配置
.idea
.vscode

# 忽略临时文件
tmp/
*.swp